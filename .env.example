# API
TOKENINDEX_API_HOST=0.0.0.0
TOKENINDEX_API_PORT=8080
# Legacy compatibility only (unified API keeps a single listener):
TOKENINDEX_MAINNET_API_HOST=
TOKENINDEX_MAINNET_API_PORT=8080
TOKENINDEX_LOG_LEVEL=info,tokenindex=debug
TOKENINDEX_CORS_ALLOW_ORIGINS=*

# Postgres
TOKENINDEX_DATABASE_URL=postgres://tokenindex:tokenindex@postgres:5432/tokenindex
TOKENINDEX_DATABASE_READ_URL=
TOKENINDEX_CHIPNET_DATABASE_URL=
TOKENINDEX_CHIPNET_DATABASE_READ_URL=
TOKENINDEX_CHIPNET_DB_SCHEMA=chipnet
TOKENINDEX_MAINNET_DATABASE_URL=
TOKENINDEX_MAINNET_DATABASE_READ_URL=
TOKENINDEX_MAINNET_DB_SCHEMA=mainnet
TOKENINDEX_DB_MAX_CONNECTIONS=30
TOKENINDEX_DB_STATEMENT_TIMEOUT_MS=5000
TOKENINDEX_DB_API_MAX_CONNECTIONS=0
TOKENINDEX_DB_INGEST_MAX_CONNECTIONS=0

# Redis (optional shared cache)
TOKENINDEX_REDIS_URL=redis://redis:6379

# BCHN chipnet RPC (primary stack on unified API)
TOKENINDEX_CHIPNET_RPC_URL=http://bchn:48334
TOKENINDEX_CHIPNET_RPC_USER=rpcuser
TOKENINDEX_CHIPNET_RPC_PASS=rpcpass
TOKENINDEX_CHIPNET_EXPECTED_CHAIN=chip
TOKENINDEX_MAINNET_RPC_URL=
TOKENINDEX_MAINNET_RPC_USER=
TOKENINDEX_MAINNET_RPC_PASS=
TOKENINDEX_MAINNET_BOOTSTRAP_HEIGHT=0

# BCHN ZMQ (optional)
TOKENINDEX_CHIPNET_ZMQ_BLOCK_ENDPOINT=tcp://bchn:8433

# Indexing
TOKENINDEX_BOOTSTRAP_HEIGHT=0
TOKENINDEX_REORG_WINDOW=20
TOKENINDEX_MEMPOOL_ENABLED=true
TOKENINDEX_MEMPOOL_POLL_MS=1500
TOKENINDEX_MEMPOOL_MAX_TXS=50000
TOKENINDEX_BCMR_ENABLED=true
TOKENINDEX_BCMR_POLL_MS=1500
TOKENINDEX_BCMR_BATCH_SIZE=32
TOKENINDEX_BCMR_MAX_ATTEMPTS=5
TOKENINDEX_BCMR_RETRY_BACKOFF_SECS=30
TOKENINDEX_BCMR_MAX_AUTHCHAIN_DEPTH=512
TOKENINDEX_BCMR_HTTP_TIMEOUT_MS=15000
TOKENINDEX_BCMR_MAX_RESPONSE_BYTES=1000000
TOKENINDEX_BCMR_IPFS_GATEWAYS=https://ipfs.optnlabs.com/ipfs/,https://ipfs-api.optnlabs.com/ipfs/,https://w3s.link/ipfs/,https://nftstorage.link/ipfs/,https://cf-ipfs.com/ipfs/,https://cloudflare-ipfs.com/ipfs/,https://ipfs.filebase.io/ipfs/
TOKENINDEX_BCMR_BACKFILL_ENABLED=false
TOKENINDEX_BCMR_BACKFILL_FROM_HEIGHT=0
TOKENINDEX_BCMR_BACKFILL_TO_HEIGHT=0
TOKENINDEX_BCMR_BACKFILL_BATCH_BLOCKS=200
TOKENINDEX_CONSISTENCY_CHECK_INTERVAL=100
TOKENINDEX_RECONCILE_ENABLED=true
TOKENINDEX_RECONCILE_INTERVAL_SECS=120
TOKENINDEX_RPC_TIMEOUT_MS=10000
TOKENINDEX_RPC_RETRIES=2
TOKENINDEX_RPC_RETRY_BACKOFF_MS=200
TOKENINDEX_RPC_BATCH_SIZE=100

# Caching / stale serving
TOKENINDEX_CACHE_MAX_ITEMS=50000
TOKENINDEX_CACHE_TTL_SECS=15
TOKENINDEX_STALE_WHILE_ERROR_SECS=30
TOKENINDEX_DATASET_VERSION=v1

# API protection
TOKENINDEX_API_CONCURRENCY_LIMIT=2048
TOKENINDEX_RATE_LIMIT_DEFAULT_RPS=200
TOKENINDEX_RATE_LIMIT_HOLDERS_RPS=60
TOKENINDEX_RATE_LIMIT_ELIGIBILITY_RPS=400
TOKENINDEX_API_BEARER_TOKEN=
TOKENINDEX_IP_ALLOWLIST=
TOKENINDEX_TRUSTED_PROXY_CIDRS=
TOKENINDEX_TRUST_X_FORWARDED_FOR=false
TOKENINDEX_MAX_CURSOR_CHARS=512
